{
  "name": "@blog/styles",
  "version": "1.0.0",
  "description": "blog styles lib",
  "exports": {
    ".": {
      "import": "./src/common/index.ts",
      "types": "./src/common/index.ts"
    },
    "./common": {
      "import": "./src/common/index.ts",
      "types": "./src/common/index.ts"
    },
    "./common/*": {
      "import": ["./src/common/*", "./src/common/*.ts"],
      "types": ["./src/common/*", "./src/common/*.ts"]
    },
    "./compile": {
      "import": "./src/compile/index.ts",
      "types": "./src/compile/index.ts"
    },
    "./compile/*": {
      "import": ["./src/compile/*", "./src/compile/*.ts"],
      "types": ["./src/compile/*", "./src/compile/*.ts"]
    },
    "./fonts/*": {
      "import": ["./src/fonts/*"],
      "types": ["./src/fonts/*"]
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "npm run build -- -w",
    "lint": "eslint --quiet src/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint --quiet --fix src/**/*.{ts,tsx,js,jsx}"
  },
  "devDependencies": {
    "@blog/eslint-config": "workspace:*",
    "@blog/tsconfig": "workspace:*",
    "@types/color": "3.0.6",
    "@types/node": "20.19.28",
    "eslint": "10.2.1",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@blog/context": "workspace:*",
    "@xiao-ai/utils": "1.6.7",
    "color": "4.2.3",
    "tslib": "2.8.1"
  }
}
