{
  "name": "@blog/cli",
  "description": "blog's builder terminal",
  "version": "1.0.0",
  "author": "xiaoboost",
  "license": "MIT",
  "bin": {
    "blog": "./bin/index.js"
  },
  "scripts": {
    "clear": "rimraf ./dist",
    "build": "npm run clear && tsc -p .",
    "watch": "npm run build -- -w",
    "lint": "eslint --quiet src/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint --quiet --fix src/**/*.{ts,tsx,js,jsx}"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xiaoboost/blog"
  },
  "dependencies": {
    "@blog/core": "workspace:*",
    "@blog/types": "workspace:*",
    "dotenv": "16.6.1",
    "tslib": "2.8.1",
    "yargs": "17.7.2"
  },
  "devDependencies": {
    "@blog/eslint-config": "workspace:*",
    "@blog/tsconfig": "workspace:*",
    "@types/node": "24.12.2",
    "@types/yargs": "17.0.32",
    "eslint": "10.2.1",
    "rimraf": "5.0.5",
    "typescript": "6.0.2"
  }
}
